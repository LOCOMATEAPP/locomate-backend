{
  "info": {
    "name": "Locomate - Admin Panel APIs",
    "_postman_id": "admin-collection-v1",
    "description": "Admin Panel APIs - v1 for Locomate CRM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{admin_access_token}}"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "admin_access_token",
      "value": ""
    },
    {
      "key": "admin_refresh_token",
      "value": ""
    },
    {
      "key": "admin_email",
      "value": "admin@locomate.com"
    },
    {
      "key": "admin_password",
      "value": "admin123"
    },
    {
      "key": "mall_id",
      "value": ""
    },
    {
      "key": "floor_id",
      "value": ""
    },
    {"key": "store_id", "value": ""},
    {"key": "offer_id", "value": ""},
    {"key": "user_id", "value": ""},
    {"key": "banner_id", "value": ""}
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    if (res.data) {",
                  "        pm.collectionVariables.set('admin_access_token', res.data.accessToken);",
                  "        pm.collectionVariables.set('admin_refresh_token', res.data.refreshToken);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "auth",
                "login"
              ]
            },
            "description": "Login with admin email and password. Returns access token and refresh token."
          }
        },
        {
          "name": "2. Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{admin_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/auth/refresh-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "auth",
                "refresh-token"
              ]
            },
            "description": "Refresh expired admin access token using refresh token."
          }
        },
        {
          "name": "3. Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{admin_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "auth",
                "logout"
              ]
            },
            "description": "Logout admin and invalidate refresh token."
          }
        }
      ]
    },
    {
