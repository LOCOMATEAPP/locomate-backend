{
  "info": {
    "name": "Locomate - Mobile APIs",
    "_postman_id": "mobile-collection-v1",
    "description": "Complete Mobile App APIs - v1 with Signup & Login flows",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "phone",
      "value": "+1234567890"
    },
    {
      "key": "otp",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Check User Exists",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/check-user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "mobile",
                "auth",
                "check-user"
              ]
            },
            "description": "Check if user exists with this phone number. Returns exists: true/false"
          }
        },
        {
          "name": "2. Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    if (res.data && res.data.otp) {",
                  "        pm.collectionVariables.set('otp', res.data.otp);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/send-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "mobile",
                "auth",
                "send-otp"
              ]
            },
            "description": "Send OTP after checking user exists"
          }
        },
        {
          "name": "3. Signup (New Users)",
          "event": [],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"name\": \"John Doe\",\n  \"avatar\": \"https://example.com/avatar.jpg\",\n  \"gender\": \"male\",\n  \"dob\": \"1990-01-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "mobile",
                "auth",
                "signup"
              ]
            },
            "description": "Create new user account with name, avatar, gender, dob. No OTP verification - just user creation."
          }
        },
        {
          "name": "4. Login (Existing Users)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    if (res.data) {",
                  "        pm.collectionVariables.set('access_token', res.data.accessToken);",
                  "        pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/verify-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "mobile",
                "auth",
                "verify-otp"
              ]
            },
            "description": "For EXISTING users (exists: true) - Login with phone and OTP"
          }
        },
        {
          "name": "5. Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/refresh-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "mobile",
                "auth",
                "refresh-token"
              ]
            },
            "description": "Refresh expired access token using refresh token. Returns new access and refresh tokens."
          }
        },
        {
          "name": "6. Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "mobile",
                "auth",
                "logout"
              ]
            },
            "description": "Logout user and invalidate refresh token. Requires authentication."
          }
        }
      ]
    },
